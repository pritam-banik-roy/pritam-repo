CREATE DATABASE flight_reservation;
USE flight_reservation;

CREATE TABLE flights (
    id INT PRIMARY KEY AUTO_INCREMENT,
    flight_number VARCHAR(20),
    source VARCHAR(50),
    destination VARCHAR(50),
    departure_time VARCHAR(50),
    price DOUBLE
);



